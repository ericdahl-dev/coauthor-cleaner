---
import "../styles/global.css";

const {
  title = "Coauthor Cleaner - Clean commits. Quiet bots.",
  description = "Remove unwanted AI coauthor trailers, generated-by comments, and attribution boilerplate from commits, staged changes, and pull requests.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#08090d" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://ericdahl-dev.github.io/coauthor-cleaner/" />
    <meta property="og:image" content="https://ericdahl-dev.github.io/coauthor-cleaner/og.svg" />
    <meta name="twitter:card" content="summary_large_image" />
    <title>{title}</title>
  </head>
  <body>
    <div class="noise" aria-hidden="true"></div>
    <slot />
  </body>
</html>
